{
  "name": "image-report-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for image-report skill with centralized model selection",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "image-report-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "token": "node scripts/manage-token.js",
    "token:list": "node scripts/manage-token.js list",
    "token:show": "node scripts/manage-token.js show",
    "img": "node scripts/image-modifier.js",
    "img:compress": "node scripts/image-modifier.js compress",
    "img:resize": "node scripts/image-modifier.js resize",
    "img:rotate": "node scripts/image-modifier.js rotate",
    "img:convert": "node scripts/image-modifier.js convert",
    "img:batch": "node scripts/image-modifier.js batch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "sharp": "^0.33.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "tsx": "^4.0.0"
  }
}
